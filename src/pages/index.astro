---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import BarChart from '../components/BarChart.astro';
import { loadProjects, loadDimensions } from '../lib/loadData';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const projects = loadProjects();
const dimensions = loadDimensions();
const categories = [...new Set(projects.map(p => p.category))];
const topProjects = [...projects].sort((a, b) => {
  const aAvg = Object.values(a.scores).filter((v): v is number => v !== null).reduce((s, v) => s + v, 0);
  const bAvg = Object.values(b.scores).filter((v): v is number => v !== null).reduce((s, v) => s + v, 0);
  return bAvg - aAvg;
});
const featured = topProjects[0];
---

<Layout title="Harness Engineering 全链路工具链评估">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Hero -->
    <div class="mb-10">
      <div class="flex items-start justify-between">
        <div>
          <h1 class="text-3xl font-bold text-gray-900 mb-2">
            Harness Engineering 评估
          </h1>
          <p class="text-gray-500 max-w-xl text-sm leading-relaxed">
            对 AI Coding Agent、终端、技能集、治理层四个类别的开源项目进行多维度定量评估。
            维度覆盖社区影响力、工程质量、模型兼容性、安全治理、用户体验、生态开放性。
          </p>
        </div>
        <a
          href={`${base}/submit`}
          class="hidden sm:inline-flex items-center gap-1.5 bg-gray-900 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-gray-800 transition-colors shrink-0"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          提交项目
        </a>
      </div>
    </div>

    <!-- Featured Project -->
    <div class="mb-8">
      <div class="flex items-center gap-2 mb-3">
        <span class="text-xs font-semibold text-blue-600 uppercase tracking-wider">评分最高</span>
        <span class="text-xs text-gray-300">·</span>
        <span class="text-xs text-gray-400">{featured.name}</span>
      </div>
      <div class="max-w-md">
        <ProjectCard project={featured} featured={true} />
      </div>
    </div>

    <!-- Community Data Overview -->
    <div class="mb-8">
      <h2 class="text-sm font-semibold text-gray-900 mb-3">社区数据概览</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <BarChart projects={projects} metric="stars" label="GitHub Stars" />
        <BarChart projects={projects} metric="forks" label="Forks" />
        <BarChart projects={projects} metric="contributors" label="Contributors" />
      </div>
    </div>

    <!-- Category Filter -->
    <div class="flex flex-wrap items-center gap-2 mb-4">
      <span class="text-xs font-medium text-gray-400 mr-1">筛选</span>
      <button class="category-filter active text-xs px-3 py-1.5 rounded-md bg-gray-900 text-white font-medium hover:bg-gray-800 transition-colors" data-category="all">
        全部 ({projects.length})
      </button>
      {categories.map(cat => {
        const count = projects.filter(p => p.category === cat).length;
        const catLabels = { agent: 'Coding Agent', terminal: '终端', skills: '技能集', governance: '治理层' };
        return (
          <button class="category-filter text-xs px-3 py-1.5 rounded-md bg-gray-100 text-gray-600 font-medium hover:bg-gray-200 transition-colors" data-category={cat}>
            {catLabels[cat] || cat} ({count})
          </button>
        );
      })}
    </div>

    <!-- Project Grid -->
    <div id="project-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {projects.map(p => (
        <div class="project-item" data-category={p.category}>
          <ProjectCard project={p} />
        </div>
      ))}
    </div>
  </div>
</Layout>

<script>
  document.querySelectorAll('.category-filter').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.category-filter').forEach(b => {
        b.className = 'category-filter text-xs px-3 py-1.5 rounded-md bg-gray-100 text-gray-600 font-medium hover:bg-gray-200 transition-colors';
      });
      btn.className = 'category-filter active text-xs px-3 py-1.5 rounded-md bg-gray-900 text-white font-medium hover:bg-gray-800 transition-colors';

      const cat = btn.dataset.category;
      document.querySelectorAll('.project-item').forEach(item => {
        item.style.display = cat === 'all' || item.dataset.category === cat ? '' : 'none';
      });
    });
  });
</script>
