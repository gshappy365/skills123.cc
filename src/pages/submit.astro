---
import Layout from '../layouts/Layout.astro';
import { loadDimensions } from '../lib/loadData';

const dimensions = loadDimensions();
const submitUrl = 'https://github.com/gshappy365/skills123.cc/issues/new?template=submit-project.yml';
const issuesUrl = 'https://github.com/gshappy365/skills123.cc/issues';
---

<Layout title="提交项目 | Harness Engineering 评估">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-2xl font-bold text-gray-900 mb-2">提交项目</h1>
    <p class="text-gray-600 mb-8">推荐新的 Harness Engineering 工具链项目参与评估</p>

    <!-- CTA -->
    <div class="bg-blue-50 border border-blue-200 rounded-xl p-6 mb-10 text-center">
      <p class="text-blue-800 font-medium mb-3">准备好提交了吗？</p>
      <a
        href={submitUrl}
        target="_blank"
        class="inline-flex items-center gap-2 bg-blue-600 text-white px-6 py-3 rounded-lg font-medium hover:bg-blue-700 transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        在 GitHub 上提交项目
      </a>
      <p class="text-xs text-blue-600 mt-3">需要 GitHub 账号 · 提交后我们会评估并回复</p>
      <p class="text-xs text-gray-400 mt-2">
        提示：如果按钮跳转到 GitHub 登录页，登录后会自动跳转到提交表单。
        你也可以直接访问 <a href={issuesUrl} target="_blank" class="text-blue-600 hover:underline">Issues 页面</a> 选择模板。
      </p>
    </div>

    <!-- How It Works -->
    <div class="mb-10">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">提交流程</h2>
      <div class="grid grid-cols-1 sm:grid-cols-4 gap-4">
        <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
          <div class="w-8 h-8 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center text-sm font-bold mx-auto mb-2">1</div>
          <h3 class="text-sm font-medium text-gray-900 mb-1">填写表单</h3>
          <p class="text-xs text-gray-500">在 GitHub Issue 中提交项目信息</p>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
          <div class="w-8 h-8 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center text-sm font-bold mx-auto mb-2">2</div>
          <h3 class="text-sm font-medium text-gray-900 mb-1">人工评审</h3>
          <p class="text-xs text-gray-500">我们评估项目在各维度的表现</p>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
          <div class="w-8 h-8 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center text-sm font-bold mx-auto mb-2">3</div>
          <h3 class="text-sm font-medium text-gray-900 mb-1">评分定级</h3>
          <p class="text-xs text-gray-500">按 6 维度框架给出初始评分</p>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
          <div class="w-8 h-8 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center text-sm font-bold mx-auto mb-2">4</div>
          <h3 class="text-sm font-medium text-gray-900 mb-1">上线展示</h3>
          <p class="text-xs text-gray-500">数据入库，站点自动更新</p>
        </div>
      </div>
    </div>

    <!-- Review Criteria -->
    <div class="mb-10">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">评审标准</h2>
      <p class="text-sm text-gray-600 mb-4">
        我们使用以下 6 个维度对项目进行评估，每个维度 0-100 分。
        不同类别的项目适用不同维度（如终端工具不评估"模型兼容性"）。
      </p>
      <div class="space-y-3">
        {dimensions.map(dim => (
          <div class="bg-white rounded-xl border border-gray-200 p-4">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-lg">{dim.icon}</span>
              <h3 class="font-medium text-gray-900 text-sm">{dim.name}</h3>
              <span class="text-xs text-gray-400">权重 {dim.weight}%</span>
            </div>
            <p class="text-xs text-gray-500">{dim.description}</p>
            {dim.applicableCategories && (
              <p class="text-xs text-gray-400 mt-1">
                适用：{dim.applicableCategories.map(c => ({ agent: 'Coding Agent', terminal: '终端', skills: '技能集', governance: '治理层' }[c] || c)).join('、')}
              </p>
            )}
          </div>
        ))}
      </div>
    </div>

    <!-- FAQ -->
    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">常见问题</h2>
      <div class="space-y-4 text-sm">
        <div>
          <h3 class="font-medium text-gray-900 mb-1">提交后多久能得到回复？</h3>
          <p class="text-gray-600">我们通常会在 3-5 个工作日内完成初步评审并在 Issue 中回复。</p>
        </div>
        <div>
          <h3 class="font-medium text-gray-900 mb-1">任何人都可以提交吗？</h3>
          <p class="text-gray-600">是的。我们欢迎社区推荐任何与 Harness Engineering 相关的开源工具链项目，包括自己的项目。</p>
        </div>
        <div>
          <h3 class="font-medium text-gray-900 mb-1">评分会更新吗？</h3>
          <p class="text-gray-600">社区数据（stars/forks/contributors）每周自动更新。定性评分会随项目重大版本发布人工刷新。</p>
        </div>
        <div>
          <h3 class="font-medium text-gray-900 mb-1">可以申请重新评分吗？</h3>
          <p class="text-gray-600">可以。如果项目有了重大更新，可以在对应 Issue 中留言申请重新评估。</p>
        </div>
      </div>
    </div>
  </div>
</Layout>
