---
import { loadDimensions } from '../lib/loadData';

export interface Props {
  scores: Record<string, number | null>;
  projectId?: string;
}

const { scores, projectId } = Astro.props;
const dimensions = loadDimensions();
---

<div class="overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-gray-200">
        <th class="text-left py-3 px-4 font-medium text-gray-500">维度</th>
        <th class="text-left py-3 px-4 font-medium text-gray-500">权重</th>
        <th class="text-right py-3 px-4 font-medium text-gray-500">评分</th>
        <th class="w-1/3"></th>
      </tr>
    </thead>
    <tbody>
      {dimensions.filter(d => scores[d.id] !== null).map((dim) => {
        const score = scores[dim.id] as number;
        const color = score >= 70 ? 'bg-green-500' : score >= 40 ? 'bg-yellow-500' : 'bg-red-500';
        return (
          <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
            <td class="py-3 px-4">
              <div class="flex items-center gap-2">
                <span>{dim.icon}</span>
                <span class="font-medium text-gray-900">{dim.name}</span>
              </div>
            </td>
            <td class="py-3 px-4 text-gray-500">{dim.weight}%</td>
            <td class="py-3 px-4 text-right">
              <span class={`font-bold text-lg ${score >= 70 ? 'text-green-600' : score >= 40 ? 'text-yellow-600' : 'text-red-600'}`}>
                {score}
              </span>
            </td>
            <td class="py-3 px-4">
              <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                <div class={`h-full rounded-full ${color} transition-all`} style={`width: ${score}%`}></div>
              </div>
            </td>
          </tr>
        );
      })}
    </tbody>
  </table>
</div>
