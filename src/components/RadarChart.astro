---
import { loadDimensions } from '../lib/loadData';
import type { Project } from '../lib/loadData';

export interface Props {
  projects: Project[];
  selectedIds: string[];
}

const { projects, selectedIds } = Astro.props;
const dimensions = loadDimensions();
const dimColors = ['#3b82f6', '#22c55e', '#eab308', '#ef4444', '#a855f7', '#06b6d4'];

const chartData = JSON.stringify(projects.map(p => ({ id: p.id, name: p.name, scores: p.scores })));
const chartDims = JSON.stringify(dimensions.map(d => ({ id: d.id, name: d.id })));
const chartColors = JSON.stringify(dimColors);
const chartDimLabels = JSON.stringify(dimensions.map(d => ({ id: d.id, name: d.name })));
---

<div class="bg-white rounded-xl border border-gray-200 p-6">
  <div
    id="radar-chart"
    class="w-full"
    style="height: 400px;"
    data-projects={chartData}
    data-dimensions={chartDims}
    data-dim-labels={chartDimLabels}
    data-colors={chartColors}
    data-selected-ids={JSON.stringify(selectedIds)}
  ></div>
</div>

<script>
  import { init, use } from 'echarts/core';
  import { RadarChart } from 'echarts/charts';
  import { TooltipComponent, LegendComponent, RadarComponent } from 'echarts/components';
  import { CanvasRenderer } from 'echarts/renderers';
  use([RadarChart, TooltipComponent, LegendComponent, RadarComponent, CanvasRenderer]);

  const el = document.getElementById('radar-chart');
  const allProjects = JSON.parse(el.dataset.projects);
  const dimensions = JSON.parse(el.dataset.dimensions);
  const dimLabels = JSON.parse(el.dataset.dimLabels);
  const colors = JSON.parse(el.dataset.colors);

  const chart = init(el);

  function getActiveDims(project) {
    return dimensions.filter(d => project.scores[d.id] !== null);
  }

  function buildOption(selectedIds) {
    const selected = allProjects.filter(p => selectedIds.includes(p.id));
    if (selected.length === 0) return {};

    // 取所有选中项目的活跃维度并集
    const activeDimIds = new Set();
    selected.forEach(p => {
      getActiveDims(p).forEach(d => activeDimIds.add(d.id));
    });
    const activeDims = dimensions.filter(d => activeDimIds.has(d.id));

    return {
      tooltip: {},
      legend: {
        data: selected.map(p => p.name),
        bottom: 0,
      },
      radar: {
        indicator: activeDims.map(d => ({
          name: dimLabels.find(l => l.id === d.id)?.name || d.id,
          max: 100,
        })),
        center: ['50%', '45%'],
        radius: '60%',
        axisName: {
          color: '#6b7280',
          fontSize: 12,
        },
      },
      series: [{
        type: 'radar',
        data: selected.map((p, i) => ({
          name: p.name,
          value: activeDims.map(d => p.scores[d.id] ?? 0),
          areaStyle: {
            color: colors[i],
            opacity: 0.1,
          },
          lineStyle: {
            color: colors[i],
            width: 2,
          },
          itemStyle: {
            color: colors[i],
          },
        })),
      }],
    };
  }

  // 初始渲染 — 使用服务端传入的 selectedIds prop
  const initialSelected = JSON.parse(el.dataset.selectedIds || '[]');
  chart.setOption(buildOption(initialSelected.length > 0 ? initialSelected : allProjects.map(p => p.id)));

  // 监听切换事件
  window.addEventListener('projects-changed', (e) => {
    chart.setOption(buildOption(e.detail));
  });

  const resize = () => chart.resize();
  window.addEventListener('resize', resize);
</script>
