---
import type { Project } from '../lib/loadData';

export interface Props {
  projects: Project[];
  metric: 'stars' | 'forks' | 'contributors';
  label: string;
}

const { projects, metric, label } = Astro.props;
const sorted = [...projects].sort((a, b) => b.communityData[metric] - a.communityData[metric]);
const maxVal = Math.max(...projects.map(p => p.communityData[metric]));
---

<div class="bg-white rounded-lg border border-gray-200 p-4">
  <h3 class="text-xs font-semibold text-gray-900 mb-3">{label}</h3>
  <div class="space-y-2">
    {sorted.map((p) => {
      const pct = (p.communityData[metric] / maxVal) * 100;
      return (
        <div class="flex items-center gap-2">
          <span class="text-xs text-gray-500 w-20 truncate text-right shrink-0">{p.name}</span>
          <div class="flex-1 h-4 bg-gray-50 rounded-sm overflow-hidden relative">
            <div
              class="h-full rounded-sm bg-blue-500/80 transition-all"
              style={`width: ${Math.max(pct, 2)}%`}
            ></div>
          </div>
          <span class="text-xs font-mono text-gray-400 w-14 text-left shrink-0">
            {p.communityData[metric].toLocaleString()}
          </span>
        </div>
      );
    })}
  </div>
</div>
