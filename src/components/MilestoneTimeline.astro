---
import type { Milestone } from '../lib/loadData';

export interface Props {
  milestones: Milestone[];
}

const { milestones } = Astro.props;
---

<div class="relative">
  <!-- Vertical Line -->
  <div class="absolute left-5 top-0 bottom-0 w-0.5 bg-gray-200"></div>

  <div class="space-y-6">
    {milestones.map((m, i) => (
      <div class="relative flex items-start gap-4">
        <!-- Dot -->
        <div class={`relative z-10 flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold ${
          i === milestones.length - 1 ? 'bg-blue-500 text-white' : 'bg-gray-100 text-gray-500'
        }`}>
          {i + 1}
        </div>
        <!-- Content -->
        <div class="flex-1 pt-1.5">
          <div class="flex items-center gap-2 mb-1">
            <span class="text-xs text-gray-400 font-mono">{m.date}</span>
            <span class="text-sm font-semibold text-gray-900">{m.title}</span>
          </div>
          <p class="text-sm text-gray-600">{m.description}</p>
        </div>
      </div>
    ))}
  </div>
</div>
